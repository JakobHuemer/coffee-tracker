# Copy to .env and fill in. `docker compose` reads .env automatically.

# Secret used to sign and verify JWTs. MUST be at least 16 characters.
# Generate a strong random value, e.g.:  openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-secret

# Host port to publish the app on. The container serves both / (frontend) and
# /api (backend) here. Internal container port is fixed at 3001.
PORT=3001

# Published image built by CI (.github/workflows/docker.yaml). Pull this
# instead of building locally. Tags: `latest` and `sha-<commit>`.
IMAGE=ghcr.io/jakobhuemer/coffee-tracker:latest
